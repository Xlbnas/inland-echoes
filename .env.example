# Docker 与运行环境
APP_PORT=3000
RATE_LIMIT_UNITS_PER_MINUTE=60
TRUST_PROXY=false

# DeepSeek（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 阿里云百炼／通义千问（推荐用于中国大陆部署）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# SiliconFlow（经本地质量与成本测试后的推荐默认项）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash
# 可选：经过项目完整基准后由管理员维护的公开推荐目录 JSON。
SILICONFLOW_RECOMMENDED_MODELS_JSON=
# 自定义模型默认只能使用用户本次填写的临时 Key。
SILICONFLOW_ALLOW_CUSTOM_MODEL_WITH_SERVER_KEY=false
# 事实审计默认关闭；开启会增加一次或两次真实模型调用费用。
SILICONFLOW_AUDIT_MODEL=
REWRITE_FACT_AUDIT_ENABLED=false
# 基准专用（不进入普通页面请求）
SILICONFLOW_JUDGE_MODEL=
SILICONFLOW_BENCHMARK_MODELS=
SILICONFLOW_BENCHMARK_AUDIT=false
SILICONFLOW_BENCHMARK_CONCURRENCY=1
SILICONFLOW_BENCHMARK_PER_MODEL_CONCURRENCY=1

# OpenAI 兼容供应商（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6-luna

# 自定义线路默认关闭；公开部署不建议开启。
CUSTOM_PROVIDERS_ENABLED=false

# 仅在已开启自定义线路、且可信私有部署需要访问本地模型接口时启用。
ALLOW_LOCAL_PROVIDER=false
